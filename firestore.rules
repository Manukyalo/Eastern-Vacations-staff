rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 🛡️ Security Helpers ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@easternvacations.com' ||
        request.auth.token.email == 'manu@easternvacations.com'
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- 📦 CORE BUSINESS DATA ---

    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (resource.data.createdById == request.auth.token.email);
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // UPDATED: Allow authorized users to link their newly created UID to their personnel record
    match /drivers/{driverId} {
      allow read: if true; 
      allow write: if isAdmin() || (isAuthenticated() && (
        request.auth.token.email.matches('(?i)' + resource.data.email) || 
        !('uid' in resource.data) ||
        resource.data.uid == "" ||
        resource.data.uid == request.auth.uid
      ));
    }

    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // UPDATED: Allow all authenticated users to create notifications
    match /notifications/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // --- 🚛 FLEET MANAGEMENT (STAFF PWA) ---

    // UPDATED: Allow authenticated creation for own UID
    match /driverAuth/{driverId} {
      allow read: if isAdmin() || isOwner(driverId);
      allow create: if isAuthenticated(); 
      allow update: if isAdmin() || isOwner(driverId);
      allow delete: if isAdmin();
    }

    match /porters/{porterId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (resource.data.driverId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /driverLocations/{driverId} {
      allow read: if isAdmin();
      allow write: if isOwner(driverId);
    }

    match /sosAlerts/{alertId} {
      allow read: if isAdmin() || (resource.data.driverId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin(); 
      allow delete: if isAdmin();
    }

    match /tripUpdates/{updateId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // --- 🔒 DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
