rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email.lower() == 'admin@easternvacations.com' ||
        request.auth.token.email.lower() == 'manu@easternvacations.com' ||
        request.auth.token.email.lower() == 'reservations@easternvacations.com'
      );
    }

    function isAgent() {
      return isAuthenticated() && 
        request.auth.token.email.lower().matches('.*@easternvacations.com');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- 📦 CORE BUSINESS DATA ---

    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || 
        (resource.data.createdById == request.auth.token.email) || 
        (resource.data.createdById == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && (
        request.auth.token.email.lower() == resource.data.get('email', '').lower() ||
        request.auth.token.email.lower() == resource.data.get('personalEmail', '').lower() ||
        resource.data.uid == request.auth.uid
      ));
      allow delete: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isOwner(staffId) || (isAuthenticated() && 
        resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // --- 🔒 FACE ID / BIOMETRICS ---

    match /faceDescriptors/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /biometrics/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /faceAuth/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /driverFaceData/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{id} {
      allow read, write: if isAuthenticated();
    }

    // --- 🚛 FLEET MANAGEMENT ---

    match /driverAuth/{driverId} {
      allow read: if isAdmin() || isOwner(driverId);
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isOwner(driverId);
      allow delete: if isAdmin();
    }

    match /porters/{porterId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (resource.data.driverId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /driverLocations/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(driverId) || isAdmin();
    }

    match /sosAlerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /tripUpdates/{updateId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /driverMessages/{driverId} {
      allow read, write: if isAuthenticated() && (
        request.auth.uid == driverId || isAgent() || isAdmin()
      );
      
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && (
          request.auth.uid == driverId || isAgent() || isAdmin()
        );
      }
    }

    // --- ☁️ WEATHER ---

    match /weather_intelligence/{parkId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /weather_sync_stats/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /weatherData/{parkId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /weatherAdvisories/{parkId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /weatherAlerts/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /weatherHistory/{parkId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /parks/{parkId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- 🔒 DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
