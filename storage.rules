rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Driver Face Images - Managed by UID
    match /driverFaces/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: Allow read for authenticated, write for admin
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.email == 'admin@easternvacations.com' ||
        request.auth.token.email == 'manu@easternvacations.com'
      );
    }
  }
}
